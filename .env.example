# Copy to .env and fill in.  cp .env.example .env

# --- Anthropic credentials -------------------------------------------------
# Required for LIVE mode. Omit (or leave blank) to run in MOCK mode, which
# simulates Claude so you can see the full Temporal orchestration without a key.
# Create a key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- Temporal connection ---------------------------------------------------
# Local dev server (default):
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
DURABLE_CLAUDE_TASK_QUEUE=durable-claude

# Temporal Cloud (API key) — set these three; the client connects with TLS, and
# you don't run `temporal server start-dev`. Create an API key in the Cloud UI.
#   TEMPORAL_ADDRESS=<region>.<cloud_provider>.api.temporal.io:7233
#   TEMPORAL_NAMESPACE=<your-namespace>.<account-id>
#   TEMPORAL_API_KEY=<your-temporal-cloud-api-key>
#
# Self-hosted behind TLS, no API key:
#   TEMPORAL_TLS=true

# --- Models (per role) -----------------------------------------------------
# Defaults to claude-opus-4-8 everywhere. For a cheaper/faster fan-out, try:
#   AGENT_MODEL=claude-haiku-4-5
PLANNER_MODEL=claude-opus-4-8
AGENT_MODEL=claude-opus-4-8
REVIEW_MODEL=claude-opus-4-8
SYNTH_MODEL=claude-opus-4-8

# Adaptive-thinking effort per role: low | medium | high | xhigh | max
PLANNER_EFFORT=high
AGENT_EFFORT=medium
REVIEW_EFFORT=high
SYNTH_EFFORT=high

# Subagents use Claude's server-side web_search tool. Set false to disable.
ENABLE_WEB_SEARCH=true

# --- Filesystem / coding tools ---------------------------------------------
# Agent steps the planner marks use_filesystem get Claude's bash + text-editor
# tools and write real files (so coding workflows work). All file/bash ops are
# confined to the workspace dir below. Set ENABLE_FILE_TOOLS=false to disable.
ENABLE_FILE_TOOLS=true
# DURABLE_CLAUDE_WORKSPACE=./dcw_workspace

# --- Mock toggles ----------------------------------------------------------
# Force simulated Claude even if a key is present:
# DURABLE_CLAUDE_MOCK=1
# Disable the "no credentials -> mock" fallback (e.g. when using `ant auth login`):
# DURABLE_CLAUDE_NO_AUTOMOCK=1
